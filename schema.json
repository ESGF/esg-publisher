          "enum": [
            "",
            "1",
            "1e-3",
            "K",
            "Pa",
            "W m-2",
            "kg m-2 s-1",
            "m s-1",
            "m2",
            "mol m-3"
          ]
        },
        "input4mips:version": {
          "type": "string",
          "pattern": "^v(1\\d{3}|2\\d{3})(0[1-9]|1[0-2])(0[1-9]|[12]\\d|3[01])$"
        }
      },
      "patternProperties": {
        "^(?!input4mips:)": {}
      },
      "additionalProperties": false
    },
    "link_fields": {
